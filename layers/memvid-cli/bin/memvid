#!/usr/bin/env node

const { spawn } = require('child_process');
const path = require('path');
const fs = require('fs');
const os = require('os');

function getBinaryPath() {
  const platform = os.platform();
  const arch = os.arch();

  // Map to platform package names
  const platformMap = {
    'darwin-arm64': { pkg: '@memvid/cli-darwin-arm64', bin: 'memvid' },
    'darwin-x64': { pkg: '@memvid/cli-darwin-x64', bin: 'memvid' },
    'linux-x64': { pkg: '@memvid/cli-linux-x64', bin: 'memvid' },
    'win32-x64': { pkg: '@memvid/cli-win32-x64', bin: 'memvid.exe' },
  };

  const key = `${platform}-${arch}`;
  const platformInfo = platformMap[key];

  if (!platformInfo) {
    console.error(`Unsupported platform: ${platform}-${arch}`);
    console.error('Supported platforms: darwin-arm64, darwin-x64, linux-x64, win32-x64');
    process.exit(1);
  }

  // Try to find the platform package
  const possiblePaths = [
    // Standard npm install location
    path.join(__dirname, '..', 'node_modules', platformInfo.pkg, platformInfo.bin),
    // Hoisted to root node_modules
    path.join(__dirname, '..', '..', platformInfo.pkg, platformInfo.bin),
    // pnpm structure
    path.join(__dirname, '..', '..', '.pnpm', 'node_modules', platformInfo.pkg, platformInfo.bin),
  ];

  for (const binaryPath of possiblePaths) {
    if (fs.existsSync(binaryPath)) {
      return binaryPath;
    }
  }

  console.error(`Platform package not found: ${platformInfo.pkg}`);
  console.error('Tried paths:');
  possiblePaths.forEach(p => console.error(`  - ${p}`));
  console.error('\nPlease reinstall memvid-cli:');
  console.error('  npm uninstall -g memvid-cli && npm install -g memvid-cli');
  process.exit(1);
}

const binaryPath = getBinaryPath();
const args = process.argv.slice(2);

// Get the directory containing the binary (where all libraries are)
const binaryDir = path.dirname(binaryPath);

// Set up environment with library search path
const env = { ...process.env };
const platform = os.platform();

if (platform === 'linux') {
  // Add binary directory to LD_LIBRARY_PATH for Linux
  const existingPath = env.LD_LIBRARY_PATH || '';
  env.LD_LIBRARY_PATH = existingPath ? `${binaryDir}:${existingPath}` : binaryDir;
} else if (platform === 'darwin') {
  // Add binary directory to DYLD_LIBRARY_PATH for macOS
  // Note: Usually not needed if @loader_path is set correctly, but helps as fallback
  const existingPath = env.DYLD_LIBRARY_PATH || '';
  env.DYLD_LIBRARY_PATH = existingPath ? `${binaryDir}:${existingPath}` : binaryDir;
}

const child = spawn(binaryPath, args, {
  stdio: 'inherit',
  env: env,
});

child.on('error', (err) => {
  console.error(`Failed to start memvid: ${err.message}`);
  process.exit(1);
});

child.on('close', (code) => {
  process.exit(code || 0);
});
